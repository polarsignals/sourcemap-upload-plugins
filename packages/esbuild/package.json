{
  "name": "@polarsignals/sourcemap-esbuild-plugin",
  "version": "0.1.3",
  "description": "ESBuild plugin for injecting debug IDs into JavaScript files and source maps",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "npm-run-all build:rollup build:types",
    "build:rollup": "rollup --config rollup.config.js",
    "build:types": "tsc --project types.tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "npm-run-all --parallel dev:rollup dev:types",
    "dev:rollup": "rollup --config rollup.config.js --watch",
    "dev:types": "tsc --project types.tsconfig.json --watch"
  },
  "dependencies": {
    "@polarsignals/sourcemap-core": "workspace:^"
  },
  "peerDependencies": {
    "esbuild": ">=0.17.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^4.52.2",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "esbuild",
    "sourcemap",
    "debug-id",
    "profiling",
    "polar-signals"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/polarsignals/sourcemap-upload-plugins",
    "directory": "packages/esbuild"
  }
}
