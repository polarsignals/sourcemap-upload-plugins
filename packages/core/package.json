{
  "name": "@polarsignals/sourcemap-core",
  "version": "0.1.4",
  "description": "Shared core for Polar Signals sourcemap upload plugins: debug ID generation, injection, and upload",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "type": "module",
  "scripts": {
    "build": "npm-run-all build:rollup build:types",
    "build:rollup": "rollup --config rollup.config.js",
    "build:types": "tsc --project types.tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "npm-run-all --parallel dev:rollup dev:types",
    "dev:rollup": "rollup --config rollup.config.js --watch",
    "dev:types": "tsc --project types.tsconfig.json --watch"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@parca/client": "^0.17.20",
    "@protobuf-ts/grpc-transport": "2.11.1",
    "@protobuf-ts/runtime-rpc": "2.11.1",
    "glob": "9.3.5",
    "node-fetch": "^3.3.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^4.52.2",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/polarsignals/sourcemap-upload-plugins",
    "directory": "packages/core"
  }
}
