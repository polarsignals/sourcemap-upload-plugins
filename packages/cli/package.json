{
  "name": "@polarsignals/sourcemap-cli",
  "version": "0.1.0",
  "description": "CLI tool for injecting debug IDs and uploading source maps to Polar Signals",
  "bin": {
    "sourcemap-upload": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "rollup --config rollup.config.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@polarsignals/sourcemap-core": "workspace:^"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^20.0.0",
    "rollup": "^4.52.2",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "repository": {
